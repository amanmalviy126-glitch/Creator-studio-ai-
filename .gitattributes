# Auto-detect text files and perform LF normalization
* text=auto

# Declare binary files explicitly so Git never modifies line endings or contents
*.jar binary
*.apk binary
*.aab binary
*.keystore binary
*.jks binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.zip binary

# Ensure shell scripts and gradlew have LF line endings
*.sh text eol=lf
gradlew text eol=lf
